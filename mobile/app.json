{
  "expo": {
    "name": "GroupThat",
    "slug": "groupthat",
    "version": "1.3.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "groupthat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#4A90E2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dallinhull.groupthat",
      "appleTeamId": "9P29PK6A6D",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:relaxing-flounder-31.clerk.accounts.dev",
        "webcredentials:relaxing-flounder-31.clerk.accounts.dev",
        "applinks:gt-2-peach.vercel.app",
        "applinks:invite.groupthatapp.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "GroupThat needs camera access to let you take a profile picture.",
        "NSPhotoLibraryUsageDescription": "GroupThat needs access to your photos to let you choose a profile picture.",
        "NSContactsUsageDescription": "GroupThat needs access to your contacts to let you invite friends to your groups.",
        "NSCalendarsUsageDescription": "GroupThat needs access to your calendar to add meetup events.",
        "NSCalendarsFullAccessUsageDescription": "GroupThat needs access to your calendar to add meetup events.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.dallinhull.groupthat",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS",
        "INTERNET",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "READ_CONTACTS",
        "READ_CALENDAR",
        "WRITE_CALENDAR"
      ],
      "runtimeVersion": "1.3.2",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "invite.groupthatapp.com",
              "pathPrefix": "/join"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "exclude": ["META-INF/versions/9/OSGI-INF/MANIFEST.MF"]
            }
          },
          "ios": {
            "extraPods": [
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "RecaptchaInterop", "modular_headers": true }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1fdd5250-331a-446a-a605-e00c3f56055f"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/1fdd5250-331a-446a-a605-e00c3f56055f"
    }
  }
}
